{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./generator.py --preset *)",
      "Bash(./generator.py --dry-run *)",
      "Bash(./all_ci.sh)",
      "Bash(./run_docker_build.sh)",
      "Bash(./run_docker_bench.sh)",
      "Bash(docker buildx inspect*)",
      "Bash(docker buildx ls)",
      "Bash(docker buildx create*)",
      "Bash(docker buildx build*)",
      "Bash(docker image inspect*)",
      "Bash(docker image ls*)",
      "Bash(docker images*)",
      "Bash(docker pull *)",
      "Bash(docker run --rm*)",
      "Bash(docker volume inspect*)",
      "Bash(docker volume ls)",
      "Bash(docker volume create *)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(file *)"
    ],
    "deny": [
      "Bash(docker push *)",
      "Bash(./generator.py * --push*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git commit -a --amend*)",
      "Bash(docker system prune*)",
      "Bash(docker buildx prune*)",
      "Bash(docker builder prune*)",
      "Bash(rm -rf /*)"
    ]
  }
}
